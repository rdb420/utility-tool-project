# Environment for the PYTHON tooling only (Qdrant ingestion/retrieval +
# Google Workspace check). Copy to .env.local and fill with local values;
# .env.local is gitignored. Never commit real secrets.
#
# NOTE: these are NOT the website/Vercel variables. Vercel builds `web/` and
# reads the NEXT_PUBLIC_* vars documented in `web/.env.example`
# (committed production defaults live in `web/.env.production`). The root files
# here are never read by the site or by Vercel.
GOOGLE_CLOUD_PROJECT_NUMBER=000000000000
GOOGLE_CLOUD_PROJECT_ID=example-project-id
GOOGLE_OAUTH_CLIENT_SECRET_PATH=secrets/client_secret_desktop.json
GOOGLE_OAUTH_WEB_CLIENT_SECRET_PATH=secrets/client_secret_web.json
GOOGLE_TOKEN_CACHE_PATH=secrets/google_workspace_token.json
GOOGLE_DRIVE_CORPUS_SHARED_DRIVE_ID=shared-drive-id
GOOGLE_DRIVE_CORPUS_FOLDER_ID=shared-drive-or-folder-id
GOOGLE_DRIVE_CORPUS_FOLDER_URL=https://drive.google.com/drive/folders/example
GOOGLE_SHEETS_FORMULA_WORKBOOK_ID=spreadsheet-id
GOOGLE_SHEETS_FORMULA_WORKBOOK_URL=https://docs.google.com/spreadsheets/d/example/edit
QDRANT_URL=https://example-cluster.region.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=replace-with-qdrant-api-key
QDRANT_COLLECTION=logistics_supply_chain_hybrid_v1
EMBEDDINGS_URL=https://cng420-embedding.hf.space
