# Copy to .env.local and adjust. NEXT_PUBLIC_* values are inlined at build time.
NEXT_PUBLIC_SITE_URL=https://opscrunch.com
NEXT_PUBLIC_ADS_ENABLED=false
# GA4 measurement id (public — safe to expose; it's in every page's HTML anyway).
# Leave empty to disable analytics entirely (no gtag.js is ever loaded).
NEXT_PUBLIC_GA4_ID=G-7XG10CD70E
# Google site-verification token for Search Console / AdSense. Paste the real
# token into the Vercel env — do NOT commit it. Empty = no meta tag rendered.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# AdSense account association meta tag (public id; verification only, no ad script)
NEXT_PUBLIC_ADSENSE_ACCOUNT=
