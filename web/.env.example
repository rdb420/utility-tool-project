# Website env for the Next.js app (Vercel builds `web/`). Copy to .env.local
# for local dev and adjust. NEXT_PUBLIC_* values are inlined at build time and
# shipped in page HTML, so none of them are secret. Committed production
# defaults live in .env.production; the Vercel dashboard env overrides both.
# (The repo-root .env.example is unrelated — that configures the Python tooling.)

# Canonical origin, no trailing slash.
NEXT_PUBLIC_SITE_URL=https://opscrunch.com

# Ad slots stay OFF until AdSense approval + a certified IAB TCF v2.2 CMP.
NEXT_PUBLIC_ADS_ENABLED=false

# GA4 measurement id (public — safe to expose; it's in every page's HTML anyway).
# Leave empty to disable analytics entirely (no gtag.js is ever loaded).
NEXT_PUBLIC_GA4_ID=G-7XG10CD70E

# Google site-verification token for the Search Console HTML-tag method.
# OPTIONAL: production Search Console is verified via a DNS TXT record instead,
# so this is left empty and no meta tag is rendered. Only set it (in the Vercel
# env, not committed) if you switch to the HTML-tag verification route.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# AdSense account association meta + adsbygoogle.js loader (public publisher id).
NEXT_PUBLIC_ADSENSE_ACCOUNT=ca-pub-9610958335722543

# NOTE: GTM and the consentmanager CMP were removed from the site for a clean
# rebuild — there is no GTM/dataLayer/CMP code. Re-introduce NEXT_PUBLIC_GTM_ID
# (and the layout wiring) when analytics + consent are rebuilt.
